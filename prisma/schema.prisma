generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("TURSO_DATABASE_URL")
}

model Room {
  id        String   @id @default(uuid())
  code      String   @unique // 6-chars
  status    String   @default("waiting") // waiting, rps, drafting, finished
  settings  String   // JSON string: { budget: 100000000, format: 5 | 11 }
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id         String  @id @default(uuid())
  roomId     String
  room       Room    @relation(fields: [roomId], references: [id])
  name       String
  role       String  // admin, player
  budgetLeft Int
  squad      String  // JSON string array of players
  manager    String? // JSON string
}
